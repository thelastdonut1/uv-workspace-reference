# Copy this file to `.env` at the repo root and fill in your values.
# Both front-ends discover it automatically: python-dotenv walks up from the
# package's source directory to the first .env it finds, so one file at the
# root serves both `cli` and `api`.

# Required — used by the summarizer library to call OpenAI.
OPENAI_API_KEY=sk-your-key-here

# Optional — port for the API server (defaults to 8080).
PORT=8080
